# PostgreSQL (requires Docker). Or use SQLite for local testing:
# DATABASE_URL=sqlite:///./dyslexia.db
DATABASE_URL=postgresql://dev:devpass@localhost:5432/dyslexia_db
GROQ_API_KEY=your_groq_api_key_here

# OCR: hard = TrOCR Large (best accuracy)
QUALITY_MODE=hard

# TrOCR speed: set TROCR_FAST=1 for faster inference (1 beam, fewer variants)
# TROCR_FAST=1
# TROCR_WORKERS=4

# Auth (JWT)
JWT_SECRET=change-this-in-production

# OCR pipeline (DyslexAI integration)
# OCR_MODE: notebook_parity (default, verified) | production (experimental)
OCR_MODE=notebook_parity
DYSLEXAI_DEBUG=1
DYSLEXAI_EASY_THRESHOLD=0.5
DYSLEXAI_HARD_THRESHOLD=1.8
PADDLE_LANG=en
TROCR_MODEL_NAME=microsoft/trocr-large-handwritten
BYT5_MODEL_NAME=google/byt5-small
